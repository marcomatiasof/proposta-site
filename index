<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Atendimento Automatizado com IA — Marco Matias</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --dark: #080C14;
  --dark2: #0E1420;
  --dark3: #141C2E;
  --blue: #2563EB;
  --blue2: #3B82F6;
  --cyan: #06B6D4;
  --gold: #F59E0B;
  --gold2: #FCD34D;
  --bronze: #B45309;
  --silver: #94A3B8;
  --green: #10B981;
  --red: #EF4444;
  --text: #F0F4FF;
  --text2: #94A3B8;
  --border: rgba(255,255,255,0.07);
  --card: rgba(255,255,255,0.04);
  --card2: rgba(255,255,255,0.07);
  --glow: rgba(37,99,235,0.25);
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

html { scroll-behavior: smooth; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--dark);
  color: var(--text);
  overflow-x: hidden;
  line-height: 1.7;
}

/* ─── NAV ─── */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  backdrop-filter: blur(20px);
  background: rgba(8,12,20,0.85);
  border-bottom: 1px solid var(--border);
  padding: 0 5%;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-logo {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: 1.1rem;
  background: linear-gradient(90deg, var(--blue2), var(--cyan));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.nav-links {
  display: flex;
  gap: 28px;
  list-style: none;
}

.nav-links a {
  color: var(--text2);
  text-decoration: none;
  font-size: 0.85rem;
  font-weight: 500;
  transition: color 0.2s;
}

.nav-links a:hover { color: var(--text); }

.nav-cta {
  background: var(--blue);
  color: white !important;
  padding: 7px 18px !important;
  border-radius: 8px;
  font-weight: 600 !important;
  font-size: 0.82rem !important;
  transition: background 0.2s !important;
}

.nav-cta:hover { background: var(--blue2) !important; color: white !important; }

/* ─── HERO ─── */
.hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 80px 5% 60px;
  position: relative;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 70% 50% at 50% 0%, rgba(37,99,235,0.18) 0%, transparent 70%),
    radial-gradient(ellipse 40% 40% at 80% 80%, rgba(6,182,212,0.08) 0%, transparent 60%),
    radial-gradient(ellipse 30% 30% at 20% 70%, rgba(245,158,11,0.06) 0%, transparent 60%);
}

.hero-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
  background-size: 40px 40px;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 0%, transparent 100%);
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(37,99,235,0.15);
  border: 1px solid rgba(37,99,235,0.35);
  border-radius: 100px;
  padding: 6px 16px;
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--blue2);
  margin-bottom: 28px;
  animation: fadeUp 0.8s ease both;
}

.hero h1 {
  font-family: 'Syne', sans-serif;
  font-size: clamp(2.8rem, 6vw, 5rem);
  font-weight: 800;
  line-height: 1.1;
  margin-bottom: 20px;
  animation: fadeUp 0.8s 0.1s ease both;
}

.hero h1 .accent {
  background: linear-gradient(90deg, var(--blue2), var(--cyan));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero h1 .accent2 {
  background: linear-gradient(90deg, var(--gold), var(--gold2));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-sub {
  font-size: 1.1rem;
  color: var(--text2);
  max-width: 580px;
  margin: 0 auto 36px;
  animation: fadeUp 0.8s 0.2s ease both;
}

.hero-btns {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
  animation: fadeUp 0.8s 0.3s ease both;
  margin-bottom: 60px;
}

.btn-primary {
  background: var(--blue);
  color: white;
  padding: 13px 28px;
  border-radius: 10px;
  text-decoration: none;
  font-weight: 700;
  font-size: 0.95rem;
  transition: all 0.2s;
  box-shadow: 0 0 30px rgba(37,99,235,0.3);
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.btn-primary:hover {
  background: var(--blue2);
  transform: translateY(-2px);
  box-shadow: 0 0 40px rgba(37,99,235,0.5);
}

.btn-outline {
  background: transparent;
  color: var(--text);
  padding: 13px 28px;
  border-radius: 10px;
  text-decoration: none;
  font-weight: 600;
  font-size: 0.95rem;
  border: 1px solid var(--border);
  transition: all 0.2s;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.btn-outline:hover { border-color: rgba(255,255,255,0.2); background: var(--card); }

.hero-stats {
  display: flex;
  gap: 48px;
  justify-content: center;
  flex-wrap: wrap;
  animation: fadeUp 0.8s 0.4s ease both;
}

.hero-stat .val {
  font-family: 'Syne', sans-serif;
  font-size: 2rem;
  font-weight: 800;
  background: linear-gradient(90deg, var(--blue2), var(--cyan));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-stat .lbl { font-size: 0.78rem; color: var(--text2); }

/* ─── SECTIONS ─── */
section { padding: 90px 5%; }

.section-label {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--blue2);
  margin-bottom: 12px;
}

.section-title {
  font-family: 'Syne', sans-serif;
  font-size: clamp(1.8rem, 3.5vw, 2.8rem);
  font-weight: 800;
  line-height: 1.2;
  margin-bottom: 16px;
}

.section-sub {
  font-size: 1rem;
  color: var(--text2);
  max-width: 560px;
  margin-bottom: 50px;
}

/* ─── HOW IT WORKS ─── */
.how-section { background: var(--dark2); }

.steps-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: 16px;
  position: relative;
}

.step-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 24px 18px;
  text-align: center;
  position: relative;
  transition: all 0.3s;
}

.step-card:hover {
  background: var(--card2);
  border-color: rgba(37,99,235,0.3);
  transform: translateY(-4px);
}

.step-num {
  position: absolute;
  top: -10px; left: 50%;
  transform: translateX(-50%);
  background: var(--blue);
  color: white;
  font-family: 'Syne', sans-serif;
  font-size: 0.7rem;
  font-weight: 800;
  padding: 2px 10px;
  border-radius: 100px;
}

.step-icon { font-size: 2rem; display: block; margin: 8px 0; }
.step-title { font-family: 'Syne', sans-serif; font-size: 0.85rem; font-weight: 700; margin-bottom: 6px; }
.step-desc { font-size: 0.78rem; color: var(--text2); line-height: 1.5; }

/* ─── PROBLEM/SOLUTION ─── */
.ps-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
  max-width: 900px;
}

.ps-card {
  background: var(--card);
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid var(--border);
}

.ps-header {
  padding: 16px 22px;
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 1rem;
}

.ps-bad .ps-header { background: rgba(239,68,68,0.1); color: #FCA5A5; border-bottom: 1px solid rgba(239,68,68,0.15); }
.ps-good .ps-header { background: rgba(16,185,129,0.1); color: #6EE7B7; border-bottom: 1px solid rgba(16,185,129,0.15); }

.ps-items { padding: 14px 22px; }
.ps-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 8px 0;
  font-size: 0.88rem;
  color: var(--text2);
  border-bottom: 1px solid var(--border);
}
.ps-item:last-child { border: none; }
.ps-item .icon { flex-shrink: 0; font-size: 1rem; margin-top: 2px; }

/* ─── PLANS ─── */
.plans-section { background: var(--dark2); }

.plans-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  max-width: 1000px;
}

.plan-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 20px;
  overflow: hidden;
  transition: all 0.3s;
  position: relative;
}

.plan-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 20px 60px rgba(0,0,0,0.4);
}

.plan-card.popular {
  border-color: rgba(37,99,235,0.5);
  box-shadow: 0 0 40px rgba(37,99,235,0.1);
}

.popular-badge {
  position: absolute;
  top: 0; left: 50%;
  transform: translateX(-50%);
  background: var(--blue);
  color: white;
  font-size: 0.7rem;
  font-weight: 700;
  padding: 4px 16px;
  border-radius: 0 0 10px 10px;
  letter-spacing: 1px;
  text-transform: uppercase;
  white-space: nowrap;
}

.plan-top {
  padding: 32px 24px 20px;
  text-align: center;
}

.plan-medal { font-size: 2.5rem; display: block; margin-bottom: 8px; }

.plan-name {
  font-family: 'Syne', sans-serif;
  font-size: 1.4rem;
  font-weight: 800;
  margin-bottom: 4px;
}

.plan-bronze .plan-name { color: #FCD34D; }
.plan-silver .plan-name { color: #CBD5E1; }
.plan-gold .plan-name { color: var(--gold); }

.plan-desc { font-size: 0.82rem; color: var(--text2); margin-bottom: 18px; }

.plan-price {
  font-family: 'Syne', sans-serif;
  font-size: 2.2rem;
  font-weight: 800;
  color: var(--text);
}

.plan-price span { font-size: 0.85rem; font-weight: 400; color: var(--text2); }
.plan-setup { font-size: 0.75rem; color: var(--text2); margin-top: 4px; }

.plan-divider { height: 1px; background: var(--border); margin: 0 24px; }

.plan-features { padding: 20px 24px; list-style: none; }
.plan-features li {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 0.84rem;
  color: var(--text2);
  padding: 7px 0;
  border-bottom: 1px solid var(--border);
}
.plan-features li:last-child { border: none; }
.plan-features li .chk { flex-shrink: 0; color: var(--green); font-weight: 700; margin-top: 1px; }

.plan-cta {
  margin: 0 24px 24px;
  display: block;
  text-align: center;
  padding: 12px;
  border-radius: 10px;
  font-weight: 700;
  font-size: 0.9rem;
  text-decoration: none;
  transition: all 0.2s;
}

.plan-bronze .plan-cta { background: rgba(180,83,9,0.2); color: #FCD34D; border: 1px solid rgba(180,83,9,0.4); }
.plan-bronze .plan-cta:hover { background: rgba(180,83,9,0.35); }
.plan-silver .plan-cta { background: rgba(37,99,235,0.2); color: #93C5FD; border: 1px solid rgba(37,99,235,0.4); }
.plan-silver .plan-cta:hover { background: rgba(37,99,235,0.35); }
.plan-gold .plan-cta { background: rgba(245,158,11,0.2); color: var(--gold); border: 1px solid rgba(245,158,11,0.4); }
.plan-gold .plan-cta:hover { background: rgba(245,158,11,0.35); }

/* ─── COMPARE TABLE ─── */
.compare-wrap {
  overflow-x: auto;
  border-radius: 16px;
  border: 1px solid var(--border);
  max-width: 900px;
}

table { width: 100%; border-collapse: collapse; }

thead th {
  padding: 14px 16px;
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 0.85rem;
  text-align: center;
  border-bottom: 1px solid var(--border);
  background: var(--dark3);
}

thead th:first-child { text-align: left; }

.th-b { color: #FCD34D; }
.th-s { color: #CBD5E1; }
.th-g { color: var(--gold); }

tbody td {
  padding: 11px 16px;
  font-size: 0.84rem;
  text-align: center;
  color: var(--text2);
  border-bottom: 1px solid var(--border);
}

tbody td:first-child { text-align: left; color: var(--text); font-weight: 500; }
tbody tr:last-child td { border: none; }
tbody tr:hover td { background: var(--card); }

.cat-tr td {
  background: var(--dark3) !important;
  color: var(--blue2) !important;
  font-weight: 700;
  font-size: 0.78rem;
  text-transform: uppercase;
  letter-spacing: 1px;
  padding: 8px 16px;
}

.yes { color: var(--green); font-size: 1.1rem; font-weight: 700; }
.no { color: rgba(255,255,255,0.15); font-size: 1rem; }
.par { color: var(--gold); font-size: 0.78rem; font-weight: 600; }

/* ─── AI SECTION ─── */
.ai-section {
  background: linear-gradient(135deg, var(--dark2), var(--dark3));
  position: relative;
  overflow: hidden;
}

.ai-section::before {
  content: '';
  position: absolute;
  top: -100px; right: -100px;
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(6,182,212,0.06), transparent 70%);
  pointer-events: none;
}

.ai-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
  margin-bottom: 40px;
}

.ai-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 26px;
  transition: all 0.3s;
}

.ai-card:hover {
  border-color: rgba(6,182,212,0.3);
  background: rgba(6,182,212,0.04);
  transform: translateY(-4px);
}

.ai-card-icon {
  font-size: 2rem;
  display: block;
  margin-bottom: 12px;
}

.ai-card-title {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 1rem;
  color: var(--cyan);
  margin-bottom: 8px;
}

.ai-card-text { font-size: 0.84rem; color: var(--text2); line-height: 1.7; }

.ai-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

.ai-stat-card {
  background: rgba(6,182,212,0.05);
  border: 1px solid rgba(6,182,212,0.15);
  border-radius: 14px;
  padding: 20px;
  text-align: center;
}

.ai-stat-card .val {
  font-family: 'Syne', sans-serif;
  font-size: 1.7rem;
  font-weight: 800;
  color: var(--gold2);
}

.ai-stat-card .lbl { font-size: 0.76rem; color: var(--text2); margin-top: 4px; line-height: 1.4; }

/* ─── TRENDS ─── */
.trends-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
}

.trend-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 22px;
  transition: all 0.3s;
}

.trend-card:hover { border-color: rgba(37,99,235,0.3); transform: translateY(-3px); }

.trend-icon { font-size: 1.8rem; margin-bottom: 10px; }
.trend-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.95rem; margin-bottom: 12px; }
.trend-items { list-style: none; }
.trend-items li {
  font-size: 0.82rem;
  color: var(--text2);
  padding: 5px 0 5px 14px;
  position: relative;
  border-bottom: 1px solid var(--border);
}
.trend-items li:last-child { border: none; }
.trend-items li::before { content: '→'; position: absolute; left: 0; color: var(--blue2); font-size: 0.75rem; }

/* ─── BEFORE/AFTER ─── */
.ba-section { background: var(--dark2); }

.ba-grid {
  display: grid;
  grid-template-columns: 1fr 60px 1fr;
  gap: 0;
  max-width: 860px;
  align-items: start;
}

.ba-col {
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid var(--border);
}

.ba-col-head {
  padding: 14px 20px;
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 0.95rem;
}

.ba-bad .ba-col-head { background: rgba(239,68,68,0.1); color: #FCA5A5; }
.ba-good .ba-col-head { background: rgba(16,185,129,0.1); color: #6EE7B7; }

.ba-col-body { padding: 8px 0; }
.ba-row {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 10px 18px;
  border-bottom: 1px solid var(--border);
  font-size: 0.85rem;
  color: var(--text2);
}
.ba-row:last-child { border: none; }
.ba-row-icon { flex-shrink: 0; }

.ba-sep {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.8rem;
  color: var(--blue2);
  font-weight: 700;
  padding-top: 60px;
}

/* ─── INTEGRATIONS ─── */
.int-diagram {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 40px;
  max-width: 800px;
  text-align: center;
}

.int-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
  margin: 16px 0;
}

.int-node {
  background: var(--dark3);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 12px 18px;
  font-size: 0.82rem;
  font-weight: 600;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5px;
  min-width: 90px;
  transition: all 0.2s;
}

.int-node:hover { border-color: rgba(37,99,235,0.4); transform: scale(1.04); }
.int-node .icon { font-size: 1.4rem; }

.int-center {
  background: var(--blue);
  border-color: var(--blue);
  padding: 18px 22px;
  min-width: 120px;
  box-shadow: 0 0 40px rgba(37,99,235,0.3);
}

.int-arrow { color: var(--blue2); font-size: 1.2rem; }

/* ─── FAQ ─── */
.faq-section { background: var(--dark2); }

.faq-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  max-width: 900px;
}

.faq-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 20px 22px;
  transition: all 0.2s;
}

.faq-card:hover { border-color: rgba(37,99,235,0.3); }

.faq-q {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 0.9rem;
  margin-bottom: 8px;
  color: var(--text);
  display: flex;
  align-items: flex-start;
  gap: 8px;
}

.faq-a { font-size: 0.84rem; color: var(--text2); line-height: 1.6; }

/* ─── CTA FINAL ─── */
.cta-section {
  background: linear-gradient(135deg, #0A1628, #0D1F3C);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.cta-section::before {
  content: '';
  position: absolute;
  top: -150px; left: 50%;
  transform: translateX(-50%);
  width: 600px; height: 600px;
  background: radial-gradient(circle, rgba(37,99,235,0.12), transparent 70%);
  pointer-events: none;
}

.cta-section .section-title { max-width: 600px; margin: 0 auto 12px; }
.cta-section .section-sub { margin: 0 auto 36px; }

.contact-chips {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 30px;
}

.chip {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 100px;
  padding: 10px 20px;
  font-size: 0.88rem;
  display: flex;
  align-items: center;
  gap: 7px;
}

.chip strong { color: var(--blue2); }

.cta-quote {
  font-size: 1rem;
  font-style: italic;
  color: var(--gold2);
  max-width: 600px;
  margin: 0 auto;
  line-height: 1.7;
  padding: 18px;
  background: rgba(245,158,11,0.06);
  border-radius: 12px;
  border: 1px solid rgba(245,158,11,0.1);
}

/* ─── FOOTER ─── */
footer {
  background: var(--dark);
  border-top: 1px solid var(--border);
  padding: 24px 5%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.8rem;
